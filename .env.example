# Frontend repo — copy to .env for local dev.

# Backend API (separate repo / deploy)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: make dev -- uses FRONTEND_PORT from Makefile if you add it to .env
# FRONTEND_PORT=5173

# Production: set the same key in Render Static Site → Environment (build-time)
# VITE_API_BASE_URL=https://your-api.onrender.com
